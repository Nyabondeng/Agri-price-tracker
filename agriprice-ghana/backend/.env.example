PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/agriprice_ghana
JWT_SECRET=replace_with_long_secure_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
PAYSTACK_SECRET_KEY=replace_with_paystack_secret
PAYSTACK_CALLBACK_URL=http://localhost:5173/donate-success
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
ALERT_PRICE_CHANGE_PERCENT=10
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASS=replace_with_password
SMTP_FROM=AgriPrice Ghana <no-reply@agripricegh.com>
